// run "rdbg -O --port=54321 -c -- bin/rails s" first
{
  "$schema": "https://puremourning.github.io/vimspector/schema/vimspector.schema.json",
  "configurations": {
    "attach running rdbg": {
      "adapter": {
        "port": 54321
      },
      "configuration": {
        "request": "attach",
        "cwd": "${workspaceRoot}",
        "localfs": true
      }
    }
  }
}
